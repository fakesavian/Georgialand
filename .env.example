# ──────────────────────────────────────────────────────────────
# Georgia Low-Cost Land Finder — Environment Variables
# Copy this file to .env.local for local development.
#
# IMPORTANT:
# - VITE_* variables are exposed to the browser bundle by Vite.
# - Never put secrets in VITE_* variables.
# - Server-only variables are used by Vercel API functions and must be
#   configured in Vercel Project → Settings → Environment Variables.
# - Do not use Supabase's Next.js NEXT_PUBLIC_* names in this Vite repo.
# ──────────────────────────────────────────────────────────────

# App identity
VITE_APP_NAME="Georgia Low-Cost Land Finder"

# ──────────────────────────────────────────────────────────────
# Public sample dataset
# This is the only CSV that should live in /public and be publicly downloadable.
# Full/paid datasets must stay out of /public and be stored in the private
# Supabase Storage bucket named protected-datasets.
# ──────────────────────────────────────────────────────────────
VITE_FREE_SAMPLE_FILE="/free_georgia_land_10_lead_sample.csv"

# ──────────────────────────────────────────────────────────────
# Site URL (used for canonical links, emails, sitemap, and OG tags)
# Set to your production Vercel URL or custom domain.
# ──────────────────────────────────────────────────────────────
VITE_SITE_URL="https://georgialandfinder.com"
SITE_URL="https://georgialandfinder.com"

# ──────────────────────────────────────────────────────────────
# Stripe Checkout Sessions
# Dashboard subscriptions use server-created Stripe Checkout Sessions.
# Browser-safe publishable key is optional today, but useful for future Stripe.js UI.
# Server-only secrets and Price IDs are consumed by Vercel API functions.
# ──────────────────────────────────────────────────────────────
VITE_STRIPE_PUBLISHABLE_KEY="pk_test_or_pk_live_your_publishable_key"
STRIPE_SECRET_KEY="sk_test_or_sk_live_your_secret_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_signing_secret"
STRIPE_DASHBOARD_STARTER_MONTHLY_PRICE_ID="price_starter_monthly"
STRIPE_DASHBOARD_STARTER_ANNUAL_PRICE_ID="price_starter_annual"
STRIPE_DASHBOARD_PRO_MONTHLY_PRICE_ID="price_pro_monthly"
STRIPE_DASHBOARD_PRO_ANNUAL_PRICE_ID="price_pro_annual"
STRIPE_DASHBOARD_INVESTOR_MONTHLY_PRICE_ID="price_investor_monthly"
STRIPE_DASHBOARD_INVESTOR_ANNUAL_PRICE_ID="price_investor_annual"

# One-time report purchase can remain on a Payment Link until migrated.
VITE_REPORT_CHECKOUT_URL="https://example.com/checkout/report"

# ──────────────────────────────────────────────────────────────
# Supabase Auth / Database / Storage
# Browser-safe publishable key is exposed to the frontend.
# Service role key and database password are server/local-only and must NEVER use a VITE_ prefix.
# ──────────────────────────────────────────────────────────────
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable__your_publishable_key"
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_DB_PASSWORD=""

# ──────────────────────────────────────────────────────────────
# Cron authentication (server-only)
# Required by /api/cron/send-alerts. The endpoint fails closed if missing.
# On Vercel Cron, set CRON_SECRET so Vercel sends Authorization: Bearer <secret>.
# ──────────────────────────────────────────────────────────────
CRON_SECRET=""

# ──────────────────────────────────────────────────────────────
# Email Provider — Resend (server-only)
# RESEND_FROM_EMAIL should be a verified sender/domain in Resend.
# ──────────────────────────────────────────────────────────────
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Georgia Land Finder <hello@georgialandfinder.com>"

# ──────────────────────────────────────────────────────────────
# Analytics
# ──────────────────────────────────────────────────────────────
VITE_ANALYTICS_PROVIDER="console"
VITE_POSTHOG_KEY=""
VITE_POSTHOG_HOST="https://app.posthog.com"
VITE_CLARITY_PROJECT_ID=""
VITE_PLAUSIBLE_DOMAIN="georgialandfinder.com"
